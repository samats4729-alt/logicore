# Database
DATABASE_URL="postgresql://logcomp:logcomp_secret@localhost:5433/logcomp?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
# Generate with: openssl rand -base64 48
JWT_SECRET="REPLACE_WITH_STRONG_RANDOM_SECRET_MIN_64_CHARS"
JWT_EXPIRES_IN="7d"

# SMS Provider - SMSC.kz
SMSC_LOGIN="your_smsc_login"
SMSC_PASSWORD="your_smsc_password"
SMSC_SENDER="LogComp"

# MinIO / S3
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY="your-s3-access-key"
S3_SECRET_KEY="your-s3-secret-key"
S3_BUCKET="logcomp-documents"

# Google Auth
GOOGLE_CLIENT_ID="your-google-client-id"

# Map & Geocoding
NEXT_PUBLIC_MAPBOX_TOKEN="your-mapbox-token"
NEXT_PUBLIC_2GIS_API_KEY="your-2gis-api-key"

# App
PORT=3001
NODE_ENV=development
