// Prisma Schema for LogComp
// Logistics Management System

generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== ENUMS ====================

enum PriceType {
  FIXED     // Всего
  PER_KM    // За км
  PER_TON   // За тонну
}

enum UserRole {
  ADMIN             // Наша компания (LogComp)
  COMPANY_ADMIN     // Админ компании-клиента (Заказчик)
  LOGISTICIAN       // Логист (создаёт заявки)
  WAREHOUSE_MANAGER // Завсклад (управляет очередью)
  ACCOUNTANT        // Бухгалтер
  DRIVER            // Водитель
  RECIPIENT         // Грузополучатель
  PARTNER           // Иная ТК (субподрядчик)
  FORWARDER         // Экспедитор
}

enum OrderStatus {
  DRAFT           // Черновик
  PENDING         // Ожидает назначения
  ASSIGNED        // Назначен водитель
  EN_ROUTE_PICKUP // Водитель едет на погрузку
  AT_PICKUP       // Водитель на месте погрузки
  LOADING         // Идет погрузка
  IN_TRANSIT      // В пути
  AT_DELIVERY     // Прибыл на выгрузку
  UNLOADING       // Идет разгрузка
  COMPLETED       // Завершен
  CANCELLED       // Отменен
  PROBLEM         // Проблема
}

enum DocumentType {
  TTN             // Товарно-транспортная накладная
  POWER_OF_ATTORNEY // Доверенность
  ACT             // Акт
  INVOICE         // Счет
  OTHER           // Прочее
}

enum CompanyType {
  CUSTOMER    // Заказчик
  FORWARDER   // Экспедитор
}

enum RoutePointType {
  PICKUP             // Погрузка
  ADDITIONAL_PICKUP  // Догруз
  DELIVERY           // Выгрузка
}

enum ContractStatus {
  DRAFT       // Черновик
  PENDING     // На согласовании
  ACTIVE      // Активен
  EXPIRED     // Истёк
  TERMINATED  // Расторгнут
}

enum AgreementStatus {
  DRAFT       // Черновик
  PENDING     // На согласовании у заказчика
  APPROVED    // Утверждено обеими сторонами
  REJECTED    // Отклонено
  EXPIRED     // Истекло
}

// Фаза 2: тип членства человека в компании
enum AffiliationType {
  EMPLOYEE         // штатный сотрудник/водитель
  PRIVATE_CARRIER  // частный перевозчик (физлицо со своей машиной)
  COLLABORATOR     // приглашённый/внешний (задел на будущее)
}

// ==================== MODELS ====================

model User {
  id            String    @id @default(cuid())
  email         String?   @unique
  googleId      String?   @unique  // Google OAuth ID
  phone         String
  passwordHash  String?   // null для водителей (SMS auth)
  firstName     String
  lastName      String
  middleName    String?
  role          UserRole
  position      String?   // Должность/роль
  avatarPath    String?   // Фото профиля (S3-ключ или локальный путь)
  permissions   String[]  @default([])
  isActive      Boolean   @default(true)
  isTrackable   Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  sessions      Session[]
  ordersAsCustomer   Order[]    @relation("CustomerOrders")
  ordersAsDriver     Order[]    @relation("DriverOrders")
  ordersAsRecipient  Order[]    @relation("RecipientOrders")
  ordersAsManager    Order[]    @relation("ManagerOrders")
  bonuses       Bonus[]
  gpsPoints     GpsPoint[]
  documents     Document[]
  orderAssignments  OrderAssignee[]  @relation("OrderAssignees")
  orderResponsibilities OrderResponsible[] @relation("UserOrderResponsibilities")
  managedExternalCompanies Company[] @relation("ExternalCompanyManager")
  orderChangeLogs   OrderChangeLog[] @relation("OrderChangeLogs")
  closedPeriods     ClosedPeriod[]
  createdInvoices   Invoice[]        @relation("InvoiceCreator")
  userCompanyRelations UserCompanyRelation[]
  
  // Компания (для PARTNER и WAREHOUSE)
  companyId     String?
  company       Company?   @relation(fields: [companyId], references: [id])

  // Фаза 1 (мультикомпанийная архитектура): ссылка на глобальную личность.
  // Пока НЕ используется существующей логикой — заполняется бэкфиллом, служит фундаментом.
  personId      String?
  person        Person?    @relation(fields: [personId], references: [id], onDelete: SetNull)

  // Отдел сотрудника
  departmentId  String?
  department    Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  
  // Водитель: данные транспорта
  iin           String?   // ИИН
  vehicleType   String?   // Тип транспорта (Тент, Реф и т.д.)
  vehiclePlate  String?   // Госномер
  vehicleModel  String?   // Модель авто
  trailerNumber String?   // Номер прицепа
  
  // Водитель: документы (удостоверение/паспорт)
  docType       String?   // Тип документа: "ID_CARD" или "PASSPORT"
  docNumber     String?   // Номер документа
  docIssuedAt   DateTime? // Дата выдачи
  docExpiresAt  DateTime? // Срок действия
  docIssuedBy   String?   // Кем выдан
  // Комиссия менеджера (% от маржи)
  commissionPercent Float     @default(0)
  
  @@index([phone])
  @@index([role])
  @@index([departmentId])
  @@index([personId])
}

// ==================== ФАЗА 1: Личность (глобальная идентичность человека) ====================
// Отдельная сущность «человек», не привязанная к компании. Фундамент для того, чтобы один
// физический водитель/сотрудник не дублировался между компаниями. На этом этапе создаётся
// бэкфиллом 1:1 и НЕ участвует в существующей логике — ничего не ломает.
model Person {
  id         String   @id @default(cuid())
  firstName  String
  lastName   String
  middleName String?
  phone      String?
  iin        String?  // ИИН
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Обратимое слияние: исходная личность не удаляется, а помечается «слита в …».
  // При откате пометка снимается, пользователи возвращаются на свои прежние личности.
  mergedIntoId String?
  mergedInto   Person?  @relation("PersonMerge", fields: [mergedIntoId], references: [id], onDelete: SetNull)
  mergedFrom   Person[] @relation("PersonMerge")

  users            User[]
  affiliations     Affiliation[]
  ownedVehicles    Vehicle[] @relation("PersonOwnedVehicles")
  operatedVehicles Vehicle[] @relation("PersonOperatedVehicles")

  @@index([phone])
  @@index([iin])
  @@index([mergedIntoId])
}

// Фаза 2: членство человека в компании (обобщает User.companyId + UserCompanyRelation).
// Один человек может иметь несколько affiliation'ов: штатный в одной, частный перевозчик в
// другой, и т.д. — без дублирования. На этом этапе таблица ЗАПОЛНЯЕТСЯ бэкфиллом и НЕ читается
// существующей логикой — ничего не ломает. Переключение чтения на неё — отдельная будущая фаза.
model Affiliation {
  id           String          @id @default(cuid())
  personId     String
  person       Person          @relation(fields: [personId], references: [id], onDelete: Cascade)
  companyId    String
  company      Company         @relation("CompanyAffiliations", fields: [companyId], references: [id], onDelete: Cascade)
  type         AffiliationType @default(EMPLOYEE)
  role         UserRole
  position     String?
  departmentId String?
  status       String          @default("ACTIVE") // ACTIVE | ARCHIVED
  isPrimary    Boolean         @default(false)     // домашняя компания (соответствует User.companyId)
  rate         Float?          // задел под кадры (ставка) — пока не используется
  startedAt    DateTime?
  endedAt      DateTime?
  sourceUserId String?         // из какого User сгенерирована связь (для сверки бэкфилла)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@unique([personId, companyId, role])
  @@index([personId])
  @@index([companyId])
  @@index([companyId, role])
}

// Журнал объединений личностей — чтобы любое слияние можно было полностью откатить.
model PersonMerge {
  id             String    @id @default(cuid())
  targetPersonId String    // основная личность, в которую объединяли
  status         String    @default("ACTIVE") // ACTIVE | REVERTED
  createdById    String?   // кто выполнил объединение
  createdAt      DateTime  @default(now())
  revertedAt     DateTime?

  items          PersonMergeItem[]

  @@index([targetPersonId])
  @@index([status])
}

// Пооперационная запись: какой пользователь и с какой прежней личности был перецеплен.
model PersonMergeItem {
  id               String      @id @default(cuid())
  mergeId          String
  merge            PersonMerge @relation(fields: [mergeId], references: [id], onDelete: Cascade)
  userId           String      // перецепленный пользователь
  previousPersonId String      // личность, на которую вернуть при откате

  @@index([mergeId])
  @@index([userId])
}

model Company {
  id             String      @id @default(cuid())
  name           String
  bin            String?     // БИН/ИИН
  address        String?     // Юридический адрес
  actualAddress  String?     // Фактический адрес
  phone          String?
  email          String?     // Email компании
  directorName   String?     // ФИО директора
  bankAccount    String?     // ИИК (номер счёта)
  bankName       String?     // Название банка
  bankBic        String?     // БИК банка
  kbe            String?     // КБЕ
  stampImage     String?     // Путь к PNG печати
  signatureImage String?     // Путь к PNG подписи
  type           CompanyType? @default(CUSTOMER)
  isCustomer     Boolean     @default(true)
  isCarrier      Boolean     @default(false)
  isOurCompany   Boolean     @default(false)  // true = LogComp
  isExternal     Boolean     @default(false)  // Внешняя компания (справочник)
  isActive       Boolean     @default(true)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  // Настройки видимости для менеджеров (LOGISTICIAN) этой компании
  managersSeeOwnOrdersOnly   Boolean @default(true)   // менеджер видит только свои заявки
  managersSeeOwnPartnersOnly Boolean @default(false)  // менеджер видит только своих контрагентов

  // Кто создал внешнюю компанию
  createdByCompanyId String?
  createdByCompany   Company?  @relation("ExternalCompanies", fields: [createdByCompanyId], references: [id])
  externalCompanies  Company[] @relation("ExternalCompanies")

  // Ответственный менеджер за внешнего контрагента (кто ведёт клиента)
  responsibleManagerId String?
  responsibleManager   User?   @relation("ExternalCompanyManager", fields: [responsibleManagerId], references: [id])

  users             User[]
  ordersAsPartner   Order[]   @relation("PartnerOrders")
  ordersAsCustomer  Order[]   @relation("CustomerCompanyOrders")
  ordersAsForwarder Order[]   @relation("ForwarderOrders")
  ordersAsSubForwarder Order[] @relation("SubForwarderOrders")

  // Partnerships
  sentRequests      Partnership[] @relation("PartnershipRequester")
  receivedRequests  Partnership[] @relation("PartnershipRecipient")

  // Contracts
  contractsAsCustomer  Contract[] @relation("ContractCustomer")
  contractsAsForwarder Contract[] @relation("ContractForwarder")
  
  invitations       Invitation[]
  locations         Location[]  @relation("CompanyLocations")
  departments       Department[]
  vehicles          Vehicle[]
  payments           Payment[] @relation("CompanyPayments")
  counterpartyPayments Payment[] @relation("CounterpartyPayments")
  closedPeriods      ClosedPeriod[]
  financeAccounts     FinanceAccount[] @relation("CompanyFinanceAccounts")
  financeCategories   FinanceCategory[] @relation("CompanyFinanceCategories")
  issuedInvoices     Invoice[]         @relation("InvoiceIssuer")
  receivedInvoices   Invoice[]         @relation("InvoiceRecipient")
  userCompanyRelations UserCompanyRelation[]
  affiliations       Affiliation[]     @relation("CompanyAffiliations")
  documents          Document[]
  subscription       CompanySubscription?
  orderResponsibilities OrderResponsible[] @relation("CompanyOrderResponsibilities")

  @@index([bin])
}

// ... existing models ...

// ==================== PARTNERSHIPS ====================

enum PartnershipStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model Partnership {
  id          String            @id @default(cuid())
  
  requesterId String
  requester   Company           @relation("PartnershipRequester", fields: [requesterId], references: [id])
  
  recipientId String
  recipient   Company           @relation("PartnershipRecipient", fields: [recipientId], references: [id])
  
  status      PartnershipStatus @default(PENDING)
  
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@unique([requesterId, recipientId])
  @@index([status])
}

model Session {
  id          String    @id @default(cuid())
  userId      String
  deviceId    String    // Для Single Session Policy
  token       String    @unique
  expiresAt   DateTime
  createdAt   DateTime  @default(now())
  
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([deviceId])
}

model Location {
  id          String    @id @default(cuid())
  name        String    // Название точки
  address     String
  latitude    Float
  longitude   Float
  contactName String?
  contactPhone String?
  city        String?   // <-- Added city field
  notes       String?
  emails      String?   // Контактные email-адреса
  companyId   String?   // ID привязанного контрагента
  company     Company?  @relation("CompanyLocations", fields: [companyId], references: [id])
  createdAt   DateTime  @default(now())
  
  // Кто создал
  createdById String?
  
  // Relations
  routePoints   OrderRoutePoint[]
  warehouseGates    WarehouseGate[]
  
  @@index([latitude, longitude])
}

model Country {
  id        String   @id @default(cuid())
  name      String   @unique // e.g., "Kazakhstan"
  code      String   @unique // e.g., "KZ"
  regions   Region[]
  cities    City[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Region {
  id        String   @id @default(cuid())
  name      String   // e.g., "Almaty Region"
  countryId String
  country   Country  @relation(fields: [countryId], references: [id])
  cities    City[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([countryId, name])
}

model City {
  id        String   @id @default(cuid())
  name      String
  latitude  Float
  longitude Float
  
  regionId  String?
  region    Region?  @relation(fields: [regionId], references: [id])
  
  countryId String
  country   Country  @relation(fields: [countryId], references: [id])

  originTariffs      RouteTariff[] @relation("OriginTariffs")
  destinationTariffs RouteTariff[] @relation("DestinationTariffs")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([countryId, regionId, name]) // Unique name per region/country
}
model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique // Номер заявки
  status          OrderStatus @default(DRAFT)
  pendingStatus     OrderStatus?
  pendingStatusById String?
  pendingStatusAt   DateTime?
  // Груз
  cargoDescription String?
  cargoWeight     Float?      // кг
  cargoVolume     Float?      // м³
  cargoLength     Float?      // Длина груза, м
  cargoWidth      Float?      // Ширина груза, м
  cargoHeight     Float?      // Высота груза, м
  palletCount     Int?        // Количество палет
  cargoType       String?     // Тип транспорта (Тент, Реф и т.д.)
  natureOfCargo   String?     // Характер груза (Сыпучие, Твердые и т.д.)
  requirements    String?     // Особые требования
  
  // Участники
  customerId      String
  customer        User        @relation("CustomerOrders", fields: [customerId], references: [id])
  
  driverId        String?
  driver          User?       @relation("DriverOrders", fields: [driverId], references: [id])
  
  recipientId     String?
  recipient       User?       @relation("RecipientOrders", fields: [recipientId], references: [id])
  
  // Если субподрядчик
  partnerId       String?
  partner         Company?    @relation("PartnerOrders", fields: [partnerId], references: [id])
  
  // Компания-заказчик
  customerCompanyId String?
  customerCompany   Company?  @relation("CustomerCompanyOrders", fields: [customerCompanyId], references: [id])
  
  // Экспедитор (назначается заказчиком)
  forwarderId       String?
  forwarder         Company?  @relation("ForwarderOrders", fields: [forwarderId], references: [id])

  // Ответственный менеджер (кто создал/ведет)
  responsibleManagerId  String?
  responsibleManager    User?  @relation("ManagerOrders", fields: [responsibleManagerId], references: [id])

  // Суб-экспедитор (назначенный основным экспедитором)
  subForwarderId    String?
  subForwarder      Company?    @relation("SubForwarderOrders", fields: [subForwarderId], references: [id])
  subForwarderPrice Float?      // Цена для суб-экспедитора
  
  // Данные водителя от экспедитора (заполняет экспедитор)
  assignedDriverName    String?   // ФИО водителя
  assignedDriverPhone   String?   // Телефон водителя
  assignedDriverPlate   String?   // Госномер авто (снимок на момент рейса)
  assignedDriverTrailer String?   // Номер прицепа
  assignedAt            DateTime? // Когда назначен водитель

  // Фаза 3: ссылка на конкретную машину (актив). Nullable, пока не пишется существующей
  // логикой — текстовые поля assignedDriver* остаются снимком. Задел под историю/переиспользование.
  vehicleId             String?
  vehicle               Vehicle?  @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  
  // Финансы
  customerPrice   Float?      // Цена для клиента (видит клиент)
  customerPriceType PriceType @default(FIXED) // Тип цены (Всего, за км, за тонну)
  driverCost      Float?      // Оплата водителю/перевозчику (скрыто от клиента)
  vatRate           Float     @default(0)
  hasVat            Boolean   @default(false)
  executorVatRate   Float     @default(0)
  executorHasVat    Boolean   @default(false)

  // Тариф по доп. соглашению (автоподстановка)
  appliedTariffId String?
  appliedTariff   RouteTariff? @relation(fields: [appliedTariffId], references: [id])
  currency        String      @default("KZT")
  
  // Подтверждение нами
  isConfirmed     Boolean     @default(false)
  confirmedAt     DateTime?
  confirmedById   String?
  
  // Статус оплаты
  isCustomerPaid      Boolean   @default(false)  // Заказчик оплатил нам
  customerPaidAt      DateTime?                   // Когда оплатил
  isDriverPaid        Boolean   @default(false)  // Мы оплатили водителю / партнёру
  driverPaidAt        DateTime?                   // Когда оплатили
  isSubForwarderPaid  Boolean   @default(false)  // Мы оплатили суб-экспедитору
  subForwarderPaidAt  DateTime?                   // Когда оплатили
  
  // --- Данные из Excel (Full List) ---
  
  // Финансы: Заказчик
  customerPaymentCondition String? // Условие оплаты (По факту, Отсрочка...)
  customerPaymentForm      String? // Форма оплаты (НДС, без НДС...)
  customerPaymentDate      DateTime? // Плановая дата оплаты
  
  // Финансы: Перевозчик
  driverPaymentCondition   String?
  driverPaymentForm        String?
  driverPaymentDate        DateTime?
  
  // Документы и коды
  ttnNumber                String? // Номер ТТН
  atiCodeCustomer          String? // Код АТИ заказчика
  atiCodeCarrier           String? // Код АТИ перевозчика
  
  // Транспорт (уточнения для рейса)
  trailerNumber            String? // Номер прицепа
  
  // Фактические данные
  actualWeight             Float?  // Вес факт
  actualVolume             Float?  // Объем факт
  
  // Timestamps
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  completedAt     DateTime?
  
  // Relations
  routePoints     OrderRoutePoint[]
  documents       Document[]
  statusHistory   OrderStatusHistory[]
  gpsPoints       GpsPoint[]
  problems        OrderProblem[]
  warehouseQueue  WarehouseQueueItem?
  expenses        Expense[]
  incomes         Income[]
  bonuses         Bonus[]
  payments        Payment[]
  assignees       OrderAssignee[]
  responsibles    OrderResponsible[]
  changeLog       OrderChangeLog[]
  incomingInvoiceId String?
  incomingInvoice   Invoice?    @relation("IncomingInvoiceOrders", fields: [incomingInvoiceId], references: [id])
  outgoingInvoiceId String?
  outgoingInvoice   Invoice?    @relation("OutgoingInvoiceOrders", fields: [outgoingInvoiceId], references: [id])
  proposedCustomerPrice Float?
  proposedDriverCost    Float?
  proposedSubForwarderPrice Float?
  
  @@index([status])
  @@index([customerId])
  @@index([driverId])
  @@index([createdAt])
  @@index([customerCompanyId, status])
  @@index([forwarderId, status])
  @@index([partnerId, status])
  @@index([responsibleManagerId])
  @@index([subForwarderId])
}

model OrderRoutePoint {
  id          String         @id @default(cuid())
  orderId     String
  order       Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  locationId  String
  location    Location       @relation(fields: [locationId], references: [id])
  
  pointType   RoutePointType
  sequence    Int            // Порядок маршрута (1, 2, 3...)
  
  expectedDate DateTime?
  notes       String?
  
  @@index([orderId])
  @@index([locationId])
}

model OrderStatusHistory {
  id          String      @id @default(cuid())
  orderId     String
  order       Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  status      OrderStatus
  comment     String?
  changedById String?
  changedAt   DateTime    @default(now())
  
  @@index([orderId])
}

model OrderProblem {
  id          String    @id @default(cuid())
  orderId     String
  order       Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  description String
  reportedById String
  resolvedAt  DateTime?
  resolution  String?
  createdAt   DateTime  @default(now())
  
  @@index([orderId])
}

model Document {
  id          String       @id @default(cuid())
  type        DocumentType
  fileName    String
  fileUrl     String       // S3 URL
  fileSize    Int
  mimeType    String
  
  orderId     String?
  order       Order?       @relation(fields: [orderId], references: [id])
  
  uploadedById String
  uploadedBy  User         @relation(fields: [uploadedById], references: [id])
  
  companyId    String?
  company      Company?     @relation(fields: [companyId], references: [id])
  
  isVerified  Boolean      @default(false)
  verifiedAt  DateTime?
  
  createdAt   DateTime     @default(now())
  
  @@index([orderId])
  @@index([type])
}

model GpsPoint {
  id          String    @id @default(cuid())
  driverId    String
  driver      User      @relation(fields: [driverId], references: [id])
  
  orderId     String?
  order       Order?    @relation(fields: [orderId], references: [id])
  
  latitude    Float
  longitude   Float
  accuracy    Float?
  speed       Float?    // км/ч
  heading     Float?    // направление
  
  recordedAt  DateTime
  receivedAt  DateTime  @default(now())
  
  @@index([driverId, recordedAt])
  @@index([orderId])
}

// ==================== WAREHOUSE ====================

model WarehouseGate {
  id          String    @id @default(cuid())
  locationId  String
  location    Location  @relation(fields: [locationId], references: [id])
  
  gateNumber  String    // Номер ворот/рампы
  isAvailable Boolean   @default(true)
  
  queueItems  WarehouseQueueItem[]
  
  @@unique([locationId, gateNumber])
}

model WarehouseQueueItem {
  id          String    @id @default(cuid())
  orderId     String    @unique
  order       Order     @relation(fields: [orderId], references: [id])
  
  gateId      String?
  gate        WarehouseGate? @relation(fields: [gateId], references: [id])
  
  arrivedAt   DateTime  @default(now())
  assignedAt  DateTime?
  startedAt   DateTime?
  completedAt DateTime?
  
  instructions String?   // "Заезжайте на ворота 3"
  
  @@index([gateId])
}


// ==================== CARGO TYPES ====================

model CargoCategory {
  id        String      @id @default(cuid())
  name      String      @unique // Название категории
  sortOrder Int         @default(0)
  types     CargoType[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

model CargoType {
  id          String        @id @default(cuid())
  name        String        // Название типа
  categoryId  String
  category    CargoCategory @relation(fields: [categoryId], references: [id])
  sortOrder   Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([categoryId])
}

// ==================== CONTRACTS & TARIFFS ====================

model Contract {
  id              String         @id @default(cuid())
  contractNumber  String         // Номер договора
  
  // Стороны
  customerCompanyId String
  customerCompany   Company      @relation("ContractCustomer", fields: [customerCompanyId], references: [id])
  
  forwarderCompanyId String
  forwarderCompany   Company    @relation("ContractForwarder", fields: [forwarderCompanyId], references: [id])
  
  status          ContractStatus @default(DRAFT)
  startDate       DateTime?
  endDate         DateTime?
  notes           String?
  content         Json?       // Содержимое: массив статей [{title, paragraphs: [{number, text}]}]
  
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  
  agreements      SupplementaryAgreement[]
  
  @@unique([customerCompanyId, forwarderCompanyId, contractNumber])
  @@index([customerCompanyId])
  @@index([forwarderCompanyId])
  @@index([status])
}

model SupplementaryAgreement {
  id              String          @id @default(cuid())
  agreementNumber String          // Номер доп. соглашения
  
  contractId      String
  contract        Contract        @relation(fields: [contractId], references: [id], onDelete: Cascade)
  
  status          AgreementStatus @default(DRAFT)
  proposedBy      String          @default("FORWARDER") // "FORWARDER" или "CUSTOMER"
  validFrom       DateTime?
  validTo         DateTime?
  notes           String?
  
  // Кто создал
  createdById     String?
  // Кто утвердил/отклонил
  approvedById    String?
  approvedAt      DateTime?
  rejectedAt      DateTime?
  rejectionReason String?
  
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  tariffs         RouteTariff[]
  
  @@index([contractId])
  @@index([status])
}

model RouteTariff {
  id              String     @id @default(cuid())
  
  agreementId     String
  agreement       SupplementaryAgreement @relation(fields: [agreementId], references: [id], onDelete: Cascade)
  
  originCityId      String
  originCity        City       @relation("OriginTariffs", fields: [originCityId], references: [id])
  destinationCityId String
  destinationCity   City       @relation("DestinationTariffs", fields: [destinationCityId], references: [id])
  
  price           Float      // Стоимость
  priceType       PriceType  @default(FIXED)
  vehicleType     String?    // Тип кузова (опционально)
  
  isActive        Boolean    @default(true)
  
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  
  orders          Order[]    // Заявки по этому тарифу
  
  @@index([agreementId])
  @@index([originCityId, destinationCityId])
}

// ==================== ACCOUNTING ====================

model Expense {
  id          String   @id @default(cuid())
  
  companyId   String
  date        DateTime
  category    String   // fuel, repair, salary, insurance, tax, rent, communication, office, penalties, other
  description String
  amount      Float    // Сумма в тенге
  note        String?
  
  // Привязка к заявке (опционально)
  orderId     String?
  order       Order?   @relation(fields: [orderId], references: [id])

  // Касса / расчётный счёт, с которого ушли деньги (опционально)
  accountId   String?
  account     FinanceAccount? @relation("AccountExpenses", fields: [accountId], references: [id], onDelete: SetNull)

  createdById String?  // Кто создал

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  isDeleted   Boolean  @default(false)

  @@index([companyId])
  @@index([companyId, date])
  @@index([category])
  @@index([orderId])
  @@index([accountId])
}

model Income {
  id          String   @id @default(cuid())
  
  companyId   String
  date        DateTime
  category    String   // order_payment, prepayment, refund, other
  description String
  amount      Float    // Сумма в тенге
  note        String?
  
  // Привязка к заявке (опционально)
  orderId     String?
  order       Order?   @relation(fields: [orderId], references: [id])

  // Касса / расчётный счёт, на который пришли деньги (опционально)
  accountId   String?
  account     FinanceAccount? @relation("AccountIncomes", fields: [accountId], references: [id], onDelete: SetNull)

  createdById String?  // Кто создал

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  isDeleted   Boolean  @default(false)

  @@index([companyId])
  @@index([companyId, date])
  @@index([category])
  @@index([orderId])
  @@index([accountId])
}

enum PaymentDirection {
  IN
  OUT
}

enum PaymentMethod {
  CASH
  BANK
  CARD
  OTHER
}

model Payment {
  id             String           @id @default(cuid())
  companyId      String
  company        Company          @relation("CompanyPayments", fields: [companyId], references: [id], onDelete: Cascade)
  orderId        String?
  order          Order?           @relation(fields: [orderId], references: [id], onDelete: SetNull)
  counterpartyId String?
  counterparty   Company?         @relation("CounterpartyPayments", fields: [counterpartyId], references: [id], onDelete: SetNull)
  direction      PaymentDirection
  amount         Float
  date           DateTime
  method         PaymentMethod    @default(BANK)
  note           String?
  createdById    String?
  isDeleted      Boolean          @default(false)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  accountId      String?
  account        FinanceAccount?  @relation("AccountPayments", fields: [accountId], references: [id], onDelete: SetNull)
  categoryId     String?
  category       FinanceCategory? @relation("CategoryPayments", fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([companyId, date])
  @@index([orderId])
  @@index([direction])
  @@index([accountId])
  @@index([categoryId])
}

enum AccountKind {
  CASH
  BANK
}

model FinanceAccount {
  id          String      @id @default(cuid())
  companyId   String
  company     Company     @relation("CompanyFinanceAccounts", fields: [companyId], references: [id], onDelete: Cascade)
  name        String
  kind        AccountKind
  isDefault   Boolean     @default(false)
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  payments    Payment[]   @relation("AccountPayments")
  incomes     Income[]    @relation("AccountIncomes")
  expenses    Expense[]   @relation("AccountExpenses")

  @@unique([companyId, name, kind])
  @@index([companyId])
}

enum CostType {
  PER_ORDER   // По заявке — себестоимость рейса (режет маржу заявки)
  PER_VEHICLE // По машине — расход конкретного ТС
  GENERAL     // Общехозяйственный — общий расход фирмы
}

model FinanceCategory {
  id          String           @id @default(cuid())
  companyId   String
  company     Company          @relation("CompanyFinanceCategories", fields: [companyId], references: [id], onDelete: Cascade)
  name        String
  direction   PaymentDirection
  costType    CostType?        // Тип статьи затрат (только для расходных, direction=OUT)
  isSystem    Boolean          @default(false)
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  payments    Payment[]        @relation("CategoryPayments")

  @@unique([companyId, name, direction])
  @@index([companyId])
}

model ClosedPeriod {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  year        Int
  month       Int      // 1-12
  closedById  String
  closedBy    User     @relation(fields: [closedById], references: [id])
  closedAt    DateTime @default(now())

  @@unique([companyId, year, month])
  @@index([companyId])
}

// ==================== BONUSES ====================

model Bonus {
  id         String   @id @default(cuid())
  userId     String   // Менеджер
  user       User     @relation(fields: [userId], references: [id])
  orderId    String   // Заявка-источник
  order      Order    @relation(fields: [orderId], references: [id])
  
  amount     Float    // Сумма бонуса
  type       String   @default("MARGIN_PERCENT") // MARGIN_PERCENT | FIXED
  percentage Float?   // Процент от маржи
  status     String   @default("PENDING") // PENDING | APPROVED | PAID
  
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  
  @@index([userId])
  @@index([orderId])
}

// ==================== INVITATIONS ====================

model Invitation {
  id           String      @id @default(cuid())
  email        String
  role         UserRole
  position     String?     // Должность/роль
  companyId    String
  token        String      @unique
  permissions  String[]    @default([])
  // Дополнительные организации, в которые сотрудник получит доступ при принятии
  // приглашения (мультикомпания). Основная — companyId. По умолчанию — все компании владельца.
  sharedCompanyIds String[] @default([])
  isUsed       Boolean     @default(false)
  expiresAt    DateTime
  createdAt    DateTime    @default(now())
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)

  company      Company     @relation(fields: [companyId], references: [id])
  
  @@index([companyId])
  @@index([token])
  @@index([departmentId])
}

// ==================== ORDER ASSIGNEES & CHANGE LOG ====================

model OrderAssignee {
  id         String   @id @default(cuid())
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation("OrderAssignees", fields: [userId], references: [id])
  assignedAt DateTime @default(now())

  @@unique([orderId, userId])
  @@index([orderId])
  @@index([userId])
}

model OrderChangeLog {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation("OrderChangeLogs", fields: [userId], references: [id])
  action    String   // "assigned", "unassigned", "updated", "status_changed", "driver_assigned", etc.
  details   String?  // Human-readable description
  createdAt DateTime @default(now())

  @@index([orderId])
}

model Department {
  id                 String       @id @default(cuid())
  name               String
  icon               String?      // Иконка отдела (например, "TruckOutlined")
  companyId          String
  company            Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  parentDepartmentId String?
  parentDepartment   Department?  @relation("DepartmentHierarchy", fields: [parentDepartmentId], references: [id], onDelete: SetNull)
  subDepartments     Department[] @relation("DepartmentHierarchy")
  
  users              User[]
  invitations        Invitation[]
  
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  @@index([companyId])
  @@index([parentDepartmentId])
}

// ==================== VEHICLES ====================

model Vehicle {
  id            String   @id @default(cuid())
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  type          String   // body type e.g., Tent, Ref
  plate         String   // license plate
  model         String   // model details
  trailerNumber String?  // optional trailer plate
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Фаза 3: транспорт как актив. Пока НЕ используется существующей логикой —
  // заполняется бэкфиллом (связь водитель↔машина реальной ссылкой вместо копирования).
  vin            String?  // задел под глобальную идентичность актива
  ownerPersonId  String?  // владелец-физлицо (частный перевозчик), если машина не компании
  ownerPerson    Person?  @relation("PersonOwnedVehicles", fields: [ownerPersonId], references: [id], onDelete: SetNull)
  driverPersonId String?  // текущий водитель (реальная ссылка, а не копия полей в User)
  driverPerson   Person?  @relation("PersonOperatedVehicles", fields: [driverPersonId], references: [id], onDelete: SetNull)

  orders        Order[]

  @@index([companyId])
  @@index([ownerPersonId])
  @@index([driverPersonId])
}

// ==================== INVOICES ====================

enum InvoiceType {
  INCOMING // Входящий (расход, от перевозчика нам)
  OUTGOING // Исходящий (доход, от нас заказчику)
}

enum InvoiceStatus {
  DRAFT      // Черновик
  PENDING    // Ожидает согласования
  DISPUTED   // Спор (корректировки по ссылке)
  APPROVED   // Согласован
  PAID       // Оплачен
  CANCELLED  // Отменен
}

model Invoice {
  id              String        @id @default(cuid())
  invoiceNumber   String        // Номер счета
  type            InvoiceType
  status          InvoiceStatus @default(DRAFT)
  
  // Эмитент и получатель
  issuerId        String
  issuer          Company       @relation("InvoiceIssuer", fields: [issuerId], references: [id], onDelete: Cascade)
  
  recipientId     String
  recipient       Company       @relation("InvoiceRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  
  date            DateTime      // Дата выставления счета
  dueDate         DateTime?     // Срок оплаты
  
  // Уникальный токен для публичной ссылки
  shareToken      String        @unique @default(uuid())
  
  // Финансовая сводка
  amount          Float         // Изначальная сумма
  adjustedAmount  Float?        // Скорректированная сумма (если был спор)
  
  note            String?
  createdById     String
  createdBy       User          @relation("InvoiceCreator", fields: [createdById], references: [id])
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  // Связи с заказами
  incomingOrders  Order[]       @relation("IncomingInvoiceOrders")
  outgoingOrders  Order[]       @relation("OutgoingInvoiceOrders")
  
  @@index([status])
  @@index([shareToken])
  @@index([issuerId])
  @@index([recipientId])
}

model UserCompanyRelation {
  id        String   @id @default(cuid())
  userId    String
  companyId String
  role      UserRole @default(COMPANY_ADMIN)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, companyId])
  @@index([userId])
  @@index([companyId])
}

// Нововведения платформы: черновики генерирует ИИ из коммитов, админ подтверждает
model PlatformUpdate {
  id            String    @id @default(cuid())
  title         String
  description   String
  sourceCommits String[]  @default([]) // sha коммитов-источников (для дедупликации)
  status        String    @default("DRAFT") // DRAFT | PUBLISHED | REJECTED
  createdAt     DateTime  @default(now())
  publishedAt   DateTime?

  @@index([status])
  @@index([createdAt])
}

// Тикеты поддержки, сформулированные ИИ-ассистентом из обращений пользователей
model SupportTicket {
  id          String   @id @default(cuid())
  companyId   String
  companyName String
  userId      String
  userName    String
  userEmail   String?
  title       String
  category    String   @default("other") // finance | orders | documents | display | other
  severity    String   @default("medium") // low | medium | high
  description String
  orders      String[] @default([]) // номера связанных заявок
  details     Json? // структура: process / where / expected / actual
  transcript  Json? // диалог пользователя с ассистентом
  status      String   @default("NEW") // NEW | IN_PROGRESS | DONE | REJECTED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([companyId])
  @@index([createdAt])
}

model PayrollScheme {
  id            String   @id @default(cuid())
  companyId     String
  userId        String?  // null = общая схема компании; задан = персональная (переопределяет общую)
  type          String   // FIXED | PERCENT | HYBRID
  fixedAmount   Float    @default(0)      // оклад в месяц (для FIXED и HYBRID)
  percentValue  Float    @default(0)      // процент (для PERCENT и HYBRID)
  percentBase   String   @default("MARGIN") // MARGIN | ORDER_AMOUNT — база процента
  accrualStatus String   @default("COMPLETED") // статус заявки-триггер: любой OrderStatus ИЛИ спец-значение CUSTOMER_PAID
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  @@unique([companyId, userId])
  @@index([companyId])
}

model PayrollKpiRule {
  id          String  @id @default(cuid())
  companyId   String
  userId      String? // null = для всех менеджеров компании
  metric      String  @default("COMPLETED_ORDERS_MONTH") // v1: количество завершённых заявок за месяц
  threshold   Int     // порог (например 20 заявок)
  bonusAmount Float   // бонус при достижении
  isActive    Boolean @default(true)
  createdAt   DateTime @default(now())
  @@index([companyId])
}

model PayrollAccrual {
  id             String   @id @default(cuid())
  companyId      String
  userId         String   // менеджер
  orderId        String?  // для kind=PERCENT; null для SALARY/KPI
  kind           String   // PERCENT | SALARY | KPI
  amount         Float
  periodMonth    String   // 'YYYY-MM' — месяц начисления
  baseAmount     Float?   // база на момент расчёта (сумма заявки или маржа)
  schemeSnapshot Json?    // снимок схемы/правила на момент расчёта
  kpiRuleId      String?
  createdAt      DateTime @default(now())
  @@unique([orderId, userId, kind])          // защита от двойного начисления по заявке
  @@unique([userId, periodMonth, kind, kpiRuleId]) // защита для SALARY/KPI за месяц
  @@index([companyId, periodMonth])
  @@index([userId, periodMonth])
}

// ==================== БИЛЛИНГ (подписки компаний) ====================

// Глобальные настройки платформы (ключ-значение)
model PlatformSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model SubscriptionPlan {
  id                String   @id @default(cuid())
  name              String
  description       String?
  priceMonthly      Int      // тенге в месяц
  currency          String   @default("KZT")
  maxUsers          Int?     // null = без лимита
  maxOrdersPerMonth Int?     // null = без лимита
  features          String[] @default([])
  isActive          Boolean  @default(true)
  sortOrder         Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  subscriptions CompanySubscription[]
}

enum SubscriptionStatus {
  TRIAL     // Пробный период
  ACTIVE    // Оплачена
  PAST_DUE  // Просрочена
  CANCELLED // Отменена
}

model CompanySubscription {
  id          String             @id @default(cuid())
  companyId   String             @unique
  company     Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  planId      String?
  plan        SubscriptionPlan?  @relation(fields: [planId], references: [id], onDelete: SetNull)
  status      SubscriptionStatus @default(TRIAL)
  trialEndsAt DateTime?
  periodStart DateTime?
  periodEnd   DateTime?
  note        String?            // Комментарий админа (№ счёта, детали оплаты)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([status])
}

// ==================== АУДИТ-ЛОГ ДЕЙСТВИЙ ====================

model AuditLog {
  id          String   @id @default(cuid())
  companyId   String?  // null = платформенное событие
  userId      String?
  userName    String?  // снимок ФИО на момент действия
  userRole    String?
  action      String   // CREATE / UPDATE / DELETE / STATUS / SETTINGS
  entity      String   // order, expense, income, payment, partner, employee, driver, subscription, ...
  entityId    String?
  entityLabel String?  // «Заявка №145», «Расход ГСМ 80 000 ₸»
  details     Json?    // старые/новые значения ключевых полей
  createdAt   DateTime @default(now())

  @@index([companyId, createdAt])
  @@index([createdAt])
}


// Ответственный менеджер от каждой компании-участника заявки
model OrderResponsible {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  companyId String
  company   Company  @relation("CompanyOrderResponsibilities", fields: [companyId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation("UserOrderResponsibilities", fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([orderId, companyId])
  @@index([userId])
  @@index([companyId])
}
