meta {
  name: Create Order
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/orders
  body: json
  auth: none
}

headers {
  Authorization: Bearer {{logisticianToken}}
}

body:json {
  {
    "routePoints": [
      {
        "locationId": "warehouse-1",
        "pointType": "PICKUP"
      },
      {
        "locationId": "delivery-1",
        "pointType": "DELIVERY"
      }
    ],
    "cargoDescription": "Test cargo description via Bruno integration tests",
    "customerPrice": 150000,
    "driverCost": 120000
  }
}

assert {
  res.status: eq 201
  res.body.id: isDefined
}

script:post-response {
  if (res.status === 201 && res.body.id) {
    bru.setVar("orderId", res.body.id);
  }
}
